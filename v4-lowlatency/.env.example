# Public URL where this app is reachable (Twilio fetches audio + webhooks from here)
PUBLIC_BASE_URL=https://your-domain.onrender.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=+1...
TWILIO_LANGUAGE=hi-IN

# Sarvam (only needed ONCE to pre-generate static MP3s — not called at runtime)
SARVAM_API_KEY=

# Tuning
TWILIO_SPEECH_TIMEOUT=2
TWILIO_GATHER_TIMEOUT=5
SESSION_TTL_MINUTES=30
MAX_RETRIES_PER_STATE=2
