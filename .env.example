# Rename this file to .env and fill in your keys

# OpenAI — powers WhatsApp conversation AI
OPENAI_API_KEY=sk-your-key-here

# Sarvam AI — powers voice call TTS (Hindi/English)
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_SPEAKER=ritu
SARVAM_LANGUAGE=hi-IN

# Twilio — WhatsApp + Voice calls
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Base URL of your deployed app (for Twilio webhooks)
BASE_URL=https://parivar-saathi-bot.onrender.com
